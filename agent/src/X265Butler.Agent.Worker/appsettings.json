{
  "Agent": {
    "AgentId": "windows-gpu-01",
    "DisplayName": "Windows GPU Worker 01",
    "FfmpegPath": "ffmpeg.exe",
    "WorkRoot": "C:\\x265-butler-agent\\work",
    "PathMappings": [
      {
        "Name": "Library SMB",
        "RemotePrefix": "/library",
        "LocalPrefix": "\\\\unraid2\\entertainment\\entertainmentfiles\\New Movies"
      },
      {
        "Name": "Cache SMB",
        "RemotePrefix": "/cache",
        "LocalPrefix": "\\\\unraid2\\cache\\x265-butler"
      },
      {
        "Name": "Config SMB",
        "RemotePrefix": "/config",
        "LocalPrefix": "\\\\unraid2\\appdata\\x265-butler"
      }
    ]
  },
  "Auth": {
    "Enabled": true,
    "ApiKey": "change-me"
  },
  "Butler": {
    "Enabled": false,
    "BaseUrl": "http://localhost:3000",
    "BearerToken": "change-me",
    "PollIntervalSeconds": 5,
    "RegisterIntervalSeconds": 30,
    "AllowValidationOnlySuccess": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
